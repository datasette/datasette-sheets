{
  "name": "datasette-sheets-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write 'src/**/*.{ts,svelte}' '../e2e/**/*.ts' '*.{ts,js,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,svelte}' '../e2e/**/*.ts' '*.{ts,js,json}'",
    "lint": "eslint 'src/**/*.{ts,svelte}'",
    "lint:fix": "eslint --fix 'src/**/*.{ts,svelte}'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.4",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.2.4",
    "vitest": "^4.1.4",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}
